# --- Environment ---------------------------------------------------------------
[[ -z "$TMUX" ]] && export TERM=xterm-256color
export COLORTERM=truecolor
# Claude Code caps colors to 256 inside tmux; this bypasses that. https://github.com/anthropics/claude-code/issues/36785
export CLAUDE_CODE_TMUX_TRUECOLOR=1
export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# asdf shims and completions must precede oh-my-zsh
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
fpath=(${ASDF_DATA_DIR:-$HOME/.asdf}/completions $fpath)

# --- Oh My Zsh -----------------------------------------------------------------
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="bureau"
plugins=(git mix)
ZSH_DISABLE_COMPFIX=true  # skip insecure-dir audit on every startup

source $ZSH/oh-my-zsh.sh

# --- Aliases -------------------------------------------------------------------
alias lg="lazygit"
alias vi="nvim"
alias cl="claude"

# --- Tools ---------------------------------------------------------------------
[ -f "$HOME/.atuin/bin/env" ] && . "$HOME/.atuin/bin/env"
command -v atuin &>/dev/null && eval "$(atuin init zsh)"
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# cache swamp completions to avoid subprocess fork on every shell open
if command -v swamp &>/dev/null; then
  _swamp_comp="${ZDOTDIR:-$HOME}/.zsh_swamp_completions"
  [[ ! -f $_swamp_comp ]] && swamp completions zsh >$_swamp_comp
  source "$_swamp_comp"
fi
